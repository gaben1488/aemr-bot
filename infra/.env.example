# MAX Bot
BOT_TOKEN=
BOT_MODE=polling
# polling | webhook

# webhook params (нужны только при BOT_MODE=webhook)
WEBHOOK_URL=
# https://feedback.elizovomr.ru/max/webhook
WEBHOOK_SECRET=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# Postgres
POSTGRES_DB=aemr
POSTGRES_USER=aemr
POSTGRES_PASSWORD=change-me-strong
DATABASE_URL=postgresql+asyncpg://aemr:change-me-strong@db:5432/aemr

# =====================================================================
# Admin group and operator roles
# =====================================================================
#
# ADMIN_GROUP_ID — ID служебной группы в MAX, куда добавлен бот и где
# работают операторы. Узнать: добавить бота в группу, написать /whoami,
# взять chat_id из ответа. Отрицательное число (например, -74181728103785).
# Без этого значения бот игнорирует группу — каждое сообщение в ней
# обрабатывается как от жителя.
#
# Роли операторов (хранятся в таблице `operators`, регистрируются через
# /add_operators в админ-группе):
#
#   it          — ИТ-специалист. Полный доступ: ответы жителям, /stats,
#                 /reopen, /close, /diag, /broadcast, плюс «опасные»:
#                 /erase (удаление ПДн), /setting (настройки),
#                 /add_operators (регистрация других). Один человек
#                 с ролью `it` фактически = «координатор + админ»,
#                 потому что `it` включает все права координатора.
#
#   coordinator — координатор АЕМР. Ответы жителям, /stats, /reopen,
#                 /close, /diag, /broadcast. БЕЗ /erase, /setting,
#                 /add_operators.
#
#   aemr        — рядовой специалист АЕМР. Ответы жителям, /stats,
#                 /reopen, /close, /diag. БЕЗ /broadcast и без
#                 «опасных» команд.
#
#   egp         — специалист Елизовского городского поселения. Тот же
#                 набор прав что у `aemr`. Различие — формальное (для
#                 audit_log и будущей маршрутизации обращений по адресу).
#
# Cold-start: при пустой таблице `operators` команда /add_operators
# не работает (она требует роль `it`, которой ещё нет). Решение —
# заполнить BOOTSTRAP_IT_MAX_USER_ID. При первом старте бота, если
# таблица operators не содержит ни одного активного `it`, будет
# вставлена запись с ролью `it`. Дальше добавляешь остальных через
# /add_operators в группе.

ADMIN_GROUP_ID=
BOOTSTRAP_IT_MAX_USER_ID=
BOOTSTRAP_IT_FULL_NAME=

# Behaviour
TZ=Asia/Kamchatka
SLA_RESPONSE_HOURS=4
APPEAL_TIMEOUT=60
ANSWER_MAX_CHARS=300
NAME_MAX_CHARS=120
ADDRESS_MAX_CHARS=500
RECOVER_BATCH_SIZE=1000
LOG_LEVEL=INFO

# Per-appeal hard caps (всё env-tunable; меняйте только если знаете зачем)
SUMMARY_MAX_CHARS=2000
ATTACHMENTS_MAX_PER_APPEAL=20
ATTACHMENTS_PER_RELAY_MESSAGE=10

# Long-polling timeout (server-side), 0..90 секунд.
# Чем выше — тем меньше пустых round-trip'ов в idle.
# Не путать с интервалом между запросами — это серверный timeout getUpdates.
POLLING_TIMEOUT_SECONDS=30

# Broadcast / рассылка
BROADCAST_MAX_CHARS=1000
BROADCAST_RATE_LIMIT_PER_SEC=1.0
BROADCAST_PROGRESS_UPDATE_SEC=5
BROADCAST_WIZARD_TTL_SEC=300

# Healthcheck
HEALTHCHECK_STALE_SECONDS=120
HEALTHCHECK_PULSE_SECONDS=30
HEALTHCHECK_INTERVAL_MIN=5

# =====================================================================
# Backup
# =====================================================================
#
# По умолчанию — еженедельный pg_dump в локальный named-volume
# (`backups`, см. docker-compose). Хранится последние BACKUP_KEEP_COUNT
# файлов с автоматической ротацией. S3 и gpg-шифрование — опциональные
# надстройки (см. ниже).
#
# Расписание: каждое <BACKUP_DAY_OF_WEEK> в <BACKUP_HOUR>:<BACKUP_MINUTE>
# по timezone бота (TZ выше). day_of_week — sun/mon/.../sat или "*"
# для каждодневного бэкапа.

BACKUP_DAY_OF_WEEK=sun
BACKUP_HOUR=3
BACKUP_MINUTE=0
BACKUP_LOCAL_DIR=/backups
BACKUP_KEEP_COUNT=8

# gpg-шифрование (опционально). Пусто — храним plain SQL. Сильно
# рекомендуется заполнять для production: пароль 32+ случайных символов.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
BACKUP_GPG_PASSPHRASE=

# S3 (опционально). Если все четыре поля заполнены — бэкап
# дополнительно заливается в облачное хранилище. Для self-hosted без
# облака — оставить пустыми, локального бэкапа достаточно.
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# External monitoring
HEALTHCHECK_URL=

# Seed
SEED_DIR=/app/seed
