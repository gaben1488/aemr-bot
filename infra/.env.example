# MAX Bot
BOT_TOKEN=
BOT_MODE=polling
# polling | webhook

# webhook params (нужны только при BOT_MODE=webhook)
WEBHOOK_URL=
# https://feedback.elizovomr.ru/max/webhook
WEBHOOK_SECRET=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# Postgres
POSTGRES_DB=aemr
POSTGRES_USER=aemr
POSTGRES_PASSWORD=change-me-strong
DATABASE_URL=postgresql+asyncpg://aemr:change-me-strong@db:5432/aemr

# Admin group and roles (заполнить после первого запуска через /whoami)
# ADMIN_GROUP_ID=
# COORDINATOR_MAX_USER_ID=

# Behaviour
TZ=Asia/Kamchatka
SLA_RESPONSE_HOURS=4
APPEAL_TIMEOUT=60
ANSWER_MAX_CHARS=300
NAME_MAX_CHARS=120
ADDRESS_MAX_CHARS=500
RECOVER_BATCH_SIZE=1000
LOG_LEVEL=INFO

# Healthcheck
HEALTHCHECK_STALE_SECONDS=120
HEALTHCHECK_PULSE_SECONDS=30
HEALTHCHECK_INTERVAL_MIN=5

# Backup schedule
BACKUP_HOUR=3
BACKUP_MINUTE=0
BACKUP_TMP_DIR=/tmp

# Backups (Yandex Object Storage пример) — на локалке не трогаем
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_GPG_PASSPHRASE=

# External monitoring
HEALTHCHECK_URL=

# Seed
SEED_DIR=/app/seed
