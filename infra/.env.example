# MAX Bot
BOT_TOKEN=
BOT_MODE=polling                       # polling | webhook
WEBHOOK_URL=                           # https://feedback.elizovomr.ru/max/webhook
WEBHOOK_SECRET=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# Postgres
POSTGRES_DB=aemr
POSTGRES_USER=aemr
POSTGRES_PASSWORD=change-me-strong
DATABASE_URL=postgresql+asyncpg://aemr:change-me-strong@db:5432/aemr

# Admin group and roles
ADMIN_GROUP_ID=                        # chat_id служебной группы (узнать через /diag)
COORDINATOR_MAX_USER_ID=

# Behaviour
TZ=Asia/Kamchatka
SLA_RESPONSE_HOURS=4
APPEAL_TIMEOUT=60                      # сек тишины до автозавершения сбора
ANSWER_MAX_CHARS=300
LOG_LEVEL=INFO

# Backups (Yandex Object Storage пример)
BACKUP_S3_ENDPOINT=https://storage.yandexcloud.net
BACKUP_S3_BUCKET=aemr-bot-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_GPG_PASSPHRASE=

# External monitoring
HEALTHCHECK_URL=                       # https://hc-ping.com/<uuid>

# Seed
SEED_DIR=/app/seed
